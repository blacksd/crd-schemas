{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "prHourlyLimit": 8,
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Helm chart versions in source config files (HTTP repos)",
      "managerFilePatterns": [
        "/^\\.sources/.*\\.yaml$/"
      ],
      "matchStrings": [
        "type:\\s*helm\\n\\s+repo:\\s*(?<registryUrl>https?://[^\\n]+)\\n\\s+chart:\\s*(?<depName>[^\\n]+)\\n\\s+version:\\s*(?<currentValue>[^\\n]+)"
      ],
      "datasourceTemplate": "helm",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Update Helm chart versions in source config files (OCI repos)",
      "managerFilePatterns": [
        "/^\\.sources/.*\\.yaml$/"
      ],
      "matchStrings": [
        "type:\\s*helm\\n\\s+repo:\\s*oci://(?<registry>[^\\n]+)\\n\\s+chart:\\s*(?<chart>[^\\n]+)\\n\\s+version:\\s*(?<currentValue>[^\\n]+)"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "{{{registry}}}/{{{chart}}}",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Update GitHub release URL versions in source config files",
      "managerFilePatterns": [
        "/^\\.sources/.*\\.yaml$/"
      ],
      "matchStrings": [
        "type:\\s*url\\n\\s+url:\\s*https://github\\.com/(?<depName>[^/]+/[^/]+)/releases/download/[^\\n]+\\n\\s+version:\\s*(?<currentValue>[^\\n]+)"
      ],
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Update raw GitHub URL versions in source config files",
      "managerFilePatterns": [
        "/^\\.sources/.*\\.yaml$/"
      ],
      "matchStrings": [
        "type:\\s*url\\n\\s+url:\\s*https://raw\\.githubusercontent\\.com/(?<depName>[^/]+/[^/]+)/[^\\n]+\\n\\s+version:\\s*(?<currentValue>[^\\n]+)"
      ],
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Update git+github source versions in source config files",
      "managerFilePatterns": [
        "/^\\.sources/.*\\.yaml$/"
      ],
      "matchStrings": [
        "type:\\s*git\\+github\\n\\s+repo:\\s*https://github\\.com/(?<depName>[^/]+/[^/]+)\\n(?:\\s+[^\\n]+\\n)*?\\s+version:\\s*(?<currentValue>[^\\n]+)"
      ],
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Track crd-schema-extractor version in CI workflow",
      "managerFilePatterns": [
        "/^\\.github/workflows/(validate-extract|extract-schemas)\\.yml$/"
      ],
      "matchStrings": [
        "EXTRACTOR_VERSION:\\s*(?<currentValue>v[^\\s]+)"
      ],
      "depNameTemplate": "blacksd/crd-schema-extractor",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "description": "Group CRD source updates by source file",
      "matchFileNames": [
        ".sources/**"
      ],
      "schedule": [
        "before 6am every weekday"
      ],
      "automerge": true,
      "automergeSchedule": [
        "at any time"
      ],
      "commitMessagePrefix": "chore(crd):"
    },
    {
      "description": "Pin and update GitHub Actions",
      "matchManagers": [
        "github-actions"
      ],
      "commitMessagePrefix": "chore(ci):"
    }
  ]
}
