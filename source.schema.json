{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blacksd/crd-schemas/source.schema.json",
  "title": "CRD Source Configuration",
  "description": "Schema for source YAML config files in the sources/ directory.",
  "type": "object",
  "required": ["sources"],
  "additionalProperties": false,
  "properties": {
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "version", "license", "homepage"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "Unique source identifier (lowercase, alphanumeric with hyphens)."
          },
          "type": {
            "type": "string",
            "enum": ["helm", "url"],
            "description": "Source type: helm chart or direct URL."
          },
          "repo": {
            "type": "string",
            "format": "uri",
            "description": "Helm repository URL. Required when type is helm."
          },
          "chart": {
            "type": "string",
            "description": "Helm chart name. Required when type is helm."
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Direct URL to a YAML manifest containing CRDs. Required when type is url."
          },
          "version": {
            "type": "string",
            "pattern": "^v?[0-9]",
            "description": "Upstream version to extract (e.g., v1.17.2)."
          },
          "license": {
            "type": "string",
            "description": "SPDX license identifier (e.g., Apache-2.0). Must permit redistribution of derived artifacts."
          },
          "homepage": {
            "type": "string",
            "format": "uri",
            "description": "Project homepage URL."
          },
          "values": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Helm --set values to pass during template rendering."
          },
          "include": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Allowlist of CRD kinds or group/kind patterns to include."
          },
          "exclude": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Denylist of CRD kinds or group/kind patterns to exclude."
          }
        },
        "allOf": [
          {
            "if": { "properties": { "type": { "const": "helm" } } },
            "then": { "required": ["repo", "chart"] }
          },
          {
            "if": { "properties": { "type": { "const": "url" } } },
            "then": { "required": ["url"] }
          }
        ]
      }
    }
  }
}
